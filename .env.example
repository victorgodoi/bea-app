# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase MCP Server (Service Role Key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Access Token
SUPABASE_ACCESS_TOKEN=your-access-token-here

# Credenciais do usuário de teste (apenas para scripts de desenvolvimento local)
TEST_USER_EMAIL=your-test-email-here
TEST_USER_PASSWORD=your-test-password-here
